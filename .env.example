# Copy this file to server/.env and fill in your values.

# Required: URL of your BirdNET-Go instance.
BIRDNET_GO_URL=http://192.168.1.10:8080

# Optional: comma-separated list if you have multiple BirdNET-Go servers.
# When set, takes precedence over BIRDNET_GO_URL. A switcher button appears in the UI.
# BIRDNET_GO_URLS=http://192.168.1.10:8080,http://192.168.1.11:8080
# BIRDNET_GO_NAMES=Garden,Office

# Optional: location for the local weather widget (defaults to London).
LAT=51.5074
LON=-0.1278

# Optional: port the kiosk server listens on.
PORT=3000

# Optional: contact URL or email for Wikimedia's User-Agent policy.
# Defaults to the Beakwatch repo URL; override if you fork and run your own.
# BEAKWATCH_CONTACT=https://github.com/your-org/your-fork
